{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "*.html",   "use": "@vercel/static" },
    { "src": "*.js",     "use": "@vercel/static", "config": { "exclude": ["api/**"] } },
    { "src": "*.css",    "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/report",   "dest": "/report.html" },
    { "src": "/",         "dest": "/index.html" }
  ]
}
