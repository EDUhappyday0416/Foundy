{
  "version": 2,
  "builds": [
    { "src": "api/*.js",      "use": "@vercel/node"   },
    { "src": "public/**",     "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/reports",  "dest": "/api/reports.js" },
    { "src": "/api/compare",  "dest": "/api/compare.js" },
    { "src": "/report",        "dest": "/public/report.html" },
    { "src": "/",             "dest": "/public/index.html"  },
    { "src": "/(.*)",         "dest": "/public/$1"          }
  ]
}
